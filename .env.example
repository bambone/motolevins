APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Локально (как на проде по смыслу): маркетинг платформы на apex, тенант на поддомене того же «корня».
# APP_URL=http://rentbase.local
# PLATFORM_HOST=platform.rentbase.local
# TENANCY_CENTRAL_DOMAINS=rentbase.local,www.rentbase.local
# TENANCY_ROOT_DOMAIN=rentbase.local
# → лендинг платформы: http://rentbase.local/ , демо-тенант: http://motolevins.rentbase.local/ , консоль: http://platform.rentbase.local/platform
# TENANT_MOTOLEVINS_PUBLIC_URL=http://motolevins.rentbase.local
# Не задавайте TENANT_DEFAULT_HOST равным apex из TENANCY_CENTRAL_DOMAINS — это хост маркетинга, не сайт клиента.
# Опционально: TENANT_DEFAULT_HOST= — лишний dev-хост в tenant_domains (например для особого сценария); можно не задавать.

APP_URL=http://localhost

# Отдельный хост для Filament Platform Console (локально: hosts / OSPanel, см. docs/operations/setup-access-deploy.md)
# PLATFORM_HOST=platform.rentbase.local

# Multi-tenant: маркетинговые хосты (через запятую), корень зоны для поддоменов тенантов, IP сервера, webroot для ACME, скрипт nginx/certbot
# TENANCY_CENTRAL_DOMAINS=rentbase.su,www.rentbase.su
# TENANCY_ROOT_DOMAIN=rentbase.su  → канонический поддомен тенанта: {slug}.rentbase.su в tenant_domains
# TENANCY_SERVER_IP=91.219.63.38
# TENANCY_CNAME_TARGET=domains.rentbase.su
# TENANCY_LE_WEBROOT=/var/www/letsencrypt
# TENANCY_PROVISION_SCRIPT=/usr/local/bin/rentbase-provision-domain
# TENANCY_PROVISION_USE_SUDO=false
# TENANCY_RESOLVER_CACHE_TTL=300
# TENANCY_LOG_VIEW_RESOLUTION=false

# Маркетинг платформы (central domains): куда слать заявки с /contact; пусто = MAIL_FROM_ADDRESS
# PLATFORM_MARKETING_CONTACT_TO=hello@rentbase.su
# Внешняя ссылка «Посмотреть демо» вместо /contact?intent=demo
# PLATFORM_MARKETING_DEMO_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# На production при CACHE_STORE=file процесс PHP-FPM должен иметь запись в storage/framework/cache
# (см. docs/operations/setup-access-deploy.md#filament-storage-cache-permissions). Иначе — database или redis.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
